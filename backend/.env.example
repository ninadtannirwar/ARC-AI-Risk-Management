# ══════════════════════════════════════════════════════════════════════════
#
#  ⚠️  This is the EXAMPLE file. Copy to .env and fill in real values.
#  ⚠️  NEVER commit your real .env to git. Add .env to .gitignore.
#
# ══════════════════════════════════════════════════════════════════════════

# ── Google Gemini AI (Tier 3 — required) ──────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Solana Wallet (live mode only — leave blank for simulation) ───────────
# Base58-encoded private key of the trading wallet
BOT_PRIVATE_KEY=your_solana_wallet_private_key_base58
BOT_PUBLIC_KEY=your_solana_wallet_public_key_base58

# ── Solana RPC Endpoints (live mode only) ─────────────────────────────────
# At least one required for live trading. Use Helius, QuickNode, or Alchemy
# for best performance. Mainnet public RPC is too slow for sniping.
RPC_URL_1=https://api.mainnet-beta.solana.com
RPC_URL_2=
RPC_URL_3=

# ── Telegram Alerts (optional but recommended) ────────────────────────────
# Create bot: https://t.me/BotFather | Get chat_id from @userinfobot
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── API Server Security ────────────────────────────────────────────────────
# X-ARC-Key header value required by Android app to authenticate
ARC_API_KEY=arc-pheonex-2026
