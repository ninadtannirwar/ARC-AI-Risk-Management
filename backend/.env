# ══════════════════════════════════════════════════════════════════════════
#  ARC — Adaptive Risk Core  ·  Singularity Engine v3.0
#  🏆 Hacksagon 2026  ·  App Development Track  |  👑 Team Pheonex
# ══════════════════════════════════════════════════════════════════════════
#
#  ⚠️  Fill in your real values before running. NEVER commit this file.
#
# ══════════════════════════════════════════════════════════════════════════

# ── Google Gemini AI (Tier 3 — required) ──────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Solana Wallet (live mode only — leave blank for simulation) ───────────
# Base58-encoded private key of your trading wallet
BOT_PRIVATE_KEY=YOUR_SOLANA_PRIVATE_KEY_BASE58_HERE
BOT_PUBLIC_KEY=YOUR_SOLANA_PUBLIC_KEY_BASE58_HERE

# ── Solana RPC Endpoints (live mode only) ─────────────────────────────────
# At least one required for live trading.
# Recommended: Helius (https://helius.dev) or QuickNode for sniper speed.
# Public mainnet RPC is too slow — use only for simulation.
RPC_URL_1=https://api.mainnet-beta.solana.com
RPC_URL_2=
RPC_URL_3=

# ── Telegram Alerts (optional but recommended) ────────────────────────────
# Create bot: https://t.me/BotFather
# Get chat_id: message @userinfobot on Telegram
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# ── API Server Security ────────────────────────────────────────────────────
# Must match the X-ARC-Key header hard-coded in the Android app.
# Do NOT change this unless you also update AppModule.kt.
ARC_API_KEY=arc-pheonex-2026

# ── Trading Mode ───────────────────────────────────────────────────────────
# true  = Paper trading (simulation, no real SOL spent) ← safe default
# false = Live trading  (real SOL)  ← only set after dry-run testing
PAPER_MODE=true

# ── Paper Trading Balance ──────────────────────────────────────────────────
# Starting virtual SOL balance for simulation mode
PAPER_STARTING_BALANCE_SOL=1.0
